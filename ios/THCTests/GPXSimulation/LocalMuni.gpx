  <!--
    LocalMuni.gpx
    9-hole fictional municipal course. No OSM data exists for these coordinates.

    Purpose:
    - Forces the Overpass API to return empty results → tap-and-save flow
    - Tests that the app correctly prompts the user to save green locations
    - Second simulation run (with cached pins) should skip tap-and-save prompts

    Location: Fictional course in suburban San Diego (~32.74°N, -117.14°W)
    Each hole: tee → mid-fairway → approach → green center
    90-second pause at each green to simulate green-to-next-tee walk

    Acceptance:
    - First run: app should show "Tap to save green location" prompt for each hole
    - Second run: distances auto-display from SwiftData cache, no prompts
  -->

  <metadata>
    <name>Local Muni — 9 Holes (No OSM Data)</name>
    <desc>Fictional 9-hole course to test tap-and-save flow when Overpass returns empty results.</desc>
    <time>2026-04-05T10:00:00Z</time>
  </metadata>

